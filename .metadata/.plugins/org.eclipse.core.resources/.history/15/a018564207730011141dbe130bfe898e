int32_t BSP_I2C1_IsReady(uint16_t DevAddr, uint32_t Trials)
{
    if (HAL_I2C_IsDeviceReady(hbus_i2c1, DevAddr, Trials, 1000) == HAL_OK) return BSP_ERROR_NONE;
    return BSP_ERROR_BUSY;
}

